# All generated artifacts (datasets, model checkpoints, metrics, logs).
# Provenance + regeneration commands live in outputs/MANIFEST.md (intentionally
# kept out of the ignore list so the manifest itself ships with the code).
outputs/

# Large model artifacts in any other location — regenerate via training
# scripts, do not check in.
*.safetensors
*.pt
*.bin
*.pkl
*.ckpt

# Python cache
__pycache__/
*.pyc
*.pyo

# OS detritus
.DS_Store
**/.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Virtualenv / pip
venv/
.venv/
*.egg-info/

# Secrets
.env
